# 火山方舟 Coding Plan — 模板，把 <REPLACE_ME> 换成真实 key 后另存为 .env
# 同一把 key 同时代理 glm-5.1 / glm-4.7 / minimax-m2.7 / minimax-m2.5 /
# doubao-seed-2.0-pro / kimi-k2.6 / deepseek-v3.2，OpenAI + Anthropic 双协议
ARK_BASE_URL_OPENAI=https://ark.cn-beijing.volces.com/api/coding/v3
ARK_BASE_URL_ANTHROPIC=https://ark.cn-beijing.volces.com/api/coding
ARK_KEY_1=<REPLACE_ME>

# anthropic SDK 默认 env 也指 Coding Plan（项目里 6 个 agent 都用 anthropic SDK）
ANTHROPIC_API_KEY=<REPLACE_ME>
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding

# 默认 model 分配（Coding Plan 模型名小写连字符）
LLM_REASONING=glm-5.1
LLM_FAST=deepseek-v3.2
LLM_DEEP=minimax-m2.7
# vision = Demo Driver / 任何需要看截图的 agent
# Coding Plan 里 kimi-k2.6 + doubao-seed-2.0-code 支持图像；glm-5.1/m2.7 text-only
LLM_VISION=kimi-k2.6

# MiniMax 国内 Token Plan — 仅用于 BGM 音乐生成（TTS 配额=0）
# Chat 不需要这把，ARK Coding Plan 已代理 minimax-m2.7
MINIMAX_API_KEY=<REPLACE_ME>
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_MUSIC_MODEL=music-2.6
